# Expo inlines EXPO_PUBLIC_* vars at bundle time. Restart `expo start -c`
# after changing this.
# Public backend (Render) — works from any network:
EXPO_PUBLIC_API_URL=https://precision-shooter-api.onrender.com
# For local backend dev, swap to your Mac's LAN IP instead:
# EXPO_PUBLIC_API_URL=http://192.168.1.77:8000
